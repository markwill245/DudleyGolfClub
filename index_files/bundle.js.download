const COURSE_DATA = [{
  hole: 1,
  name: "The Dog-Leg",
  par: 5,
  si: 9,
  yards: 478,
  desc: "A welcoming but cunning opener. A long, left-sweeping fairway demands a positive tee shot to set up the approach.",
  tip: "Keep it right off the tee. The trees on the left are trouble you don't want first thing in the morning."
}, {
  hole: 2,
  name: "The Valley",
  par: 4,
  si: 17,
  yards: 302,
  desc: "A tactical short par four that rewards accuracy over length. The green falls away to the right.",
  tip: "Leave the driver in the bag. A long iron will leave a simple pitch."
}, {
  hole: 3,
  name: "The Ridge",
  par: 3,
  si: 13,
  yards: 164,
  desc: "A testing par three played across a ridge. Club selection is everything.",
  tip: "Take one more club than you think. Wind here is deceiving."
}, {
  hole: 4,
  name: "Oakham Rise",
  par: 4,
  si: 3,
  yards: 402,
  desc: "Stroke index three for good reason. An uphill second to an elevated green guarded by deep bunkers.",
  tip: "Aim for the left half of the fairway for the best angle in."
}, {
  hole: 5,
  name: "The Meadow",
  par: 5,
  si: 11,
  yards: 501,
  desc: "A genuine three-shot hole for most. The second shot is blind over a gentle rise.",
  tip: "Layup short of the 100-yard post. Anything further brings the cross-bunker into play."
}, {
  hole: 6,
  name: "Priory View",
  par: 4,
  si: 7,
  yards: 380,
  desc: "Named for the distant view of the old priory. A straightforward drive, but the approach is all nerve.",
  tip: "Middle of the green every time — the pin is rarely worth chasing."
}, {
  hole: 7,
  name: "The Dell",
  par: 3,
  si: 15,
  yards: 148,
  desc: "A charming short par three to a bowl-shaped green. Miss short, not long.",
  tip: "Use the slope on the left — the ball will always feed right."
}, {
  hole: 8,
  name: "Captain's Drive",
  par: 4,
  si: 5,
  yards: 419,
  desc: "The signature tee box. A demanding drive over gorse to a sloping fairway.",
  tip: "Commit to the line. Indecision here always costs a shot."
}, {
  hole: 9,
  name: "The Turn",
  par: 5,
  si: 1,
  yards: 533,
  desc: "The stroke index one. Three good shots are needed to reach in regulation.",
  tip: "Don't be a hero. Par here is a birdie on the card."
}, {
  hole: 10,
  name: "Clubhouse Way",
  par: 4,
  si: 12,
  yards: 355,
  desc: "A gentle opener for the back nine with the clubhouse in view.",
  tip: "A good drive down the left opens up the pin."
}, {
  hole: 11,
  name: "Black Country",
  par: 3,
  si: 14,
  yards: 172,
  desc: "A proud par three with panoramic views across the Black Country.",
  tip: "Always play to the front edge. The back of the green is a quick two-putt at best."
}, {
  hole: 12,
  name: "The Avenue",
  par: 4,
  si: 8,
  yards: 391,
  desc: "A tree-lined fairway that demands a straight tee shot to a mid-sized green.",
  tip: "If in doubt, aim at the left edge of the fairway bunker."
}, {
  hole: 13,
  name: "Foxden",
  par: 5,
  si: 10,
  yards: 495,
  desc: "A reachable par five for longer hitters. The green is protected by water on the front-left.",
  tip: "Lay up to 90 yards if you can't get home. Inside 50 is actually harder."
}, {
  hole: 14,
  name: "The Lookout",
  par: 4,
  si: 4,
  yards: 410,
  desc: "One of the most photographed holes. A downhill tee shot to a punchbowl green.",
  tip: "Let it fly off the tee — the ground will do the rest."
}, {
  hole: 15,
  name: "Hidden Green",
  par: 3,
  si: 16,
  yards: 155,
  desc: "A blind par three, unique to Dudley. Trust your yardage and commit.",
  tip: "Aim at the bell. Ring it on your way up."
}, {
  hole: 16,
  name: "The Climb",
  par: 5,
  si: 6,
  yards: 510,
  desc: "An uphill three-shotter that bites. The second shot looks simple but rarely plays that way.",
  tip: "Take one extra club on both your second and third. This hole plays long."
}, {
  hole: 17,
  name: "Member's Pride",
  par: 4,
  si: 2,
  yards: 434,
  desc: "The toughest par four on the course. A narrow fairway and a well-guarded green.",
  tip: "A bogey here is a good score. Aim for the centre of the green, always."
}, {
  hole: 18,
  name: "Home",
  par: 4,
  si: 18,
  yards: 328,
  desc: "A charming closing hole, played to a green in front of the historic clubhouse.",
  tip: "A club-deck audience awaits. Stay in rhythm — the drive is more open than it looks."
}];
